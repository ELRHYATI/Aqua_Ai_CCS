# AZURA AQUA Backend - Environment variables
# Copy to .env and fill in values. Never commit .env.

# CORS - Frontend origin (required in production)
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL with asyncpg)
# Matches docker-compose.yml (db service)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/azura_aqua

# Chatbot read-only DB (optional, for future RAG - use chatbot_ro role)
# CHATBOT_DATABASE_URL=postgresql+asyncpg://chatbot_ro:PASSWORD@localhost:5432/azura_aqua

# Azure OpenAI - GPT-4 / GPT-4.1 / GPT-4o
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# OneDrive for Business - Excel source (Microsoft Graph)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Chemin du fichier dans OneDrive (ex. Azura Aqua/REFLEXION.xlsx)
ONEDRIVE_EXCEL_PATH=REFLEXION.xlsx
# Ou ID direct du fichier (évite la résolution du chemin)
ONEDRIVE_EXCEL_ITEM_ID=
# REQUIS pour auth app-only: Object ID utilisateur propriétaire du OneDrive
ONEDRIVE_USER_ID=
# Fallback local: chemin vers REFLEXION.xlsx (vide = cherche à la racine du projet)
EXCEL_LOCAL_PATH=

# Azure AI Search (On Your Data - indexed Excel / Power BI)
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key
AZURE_SEARCH_INDEX_NAME=azura-finance-estrans

# Copilot (optional - Copilot Studio web app URL)
COPILOT_STUDIO_WEB_APP_URL=

# LLM Tools: use Azure OpenAI Function Calling for complex questions (see docs/LLM_INTEGRATION_GUIDE.md)
# USE_LLM_TOOLS=true

# Ollama (local LLM - mistral:7b). Run: ollama pull mistral:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# Chatbot read-only DB (optional - run scripts/create_chatbot_role.sql first)
# CHATBOT_DATABASE_URL=postgresql+asyncpg://chatbot_ro:PASSWORD@localhost:5432/azura_aqua

# Auth: false = JWT obligatoire (défaut). true = mode dev (header X-User-Id, pas d’anonymous sur les privilèges)
AUTH_DISABLED=false
# Secret pour signer les JWT (production: openssl rand -hex 32)
JWT_SECRET=change-me-set-JWT_SECRET-in-production
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional
DEBUG=false
